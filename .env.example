# SMTP 邮件配置
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_authorization_code
MAIL_FROM=your_email@example.com
MAIL_TO=target_email@example.com

# Gitee 同步配置
# 推荐格式：https://用户名:私人令牌@gitee.com/用户名/仓库名.git
GITEE_REMOTE=https://username:token@gitee.com/username/starlink_intel_weekly.git

# LLM 摘要配置，可选
# 注意：ChatGPT Plus 订阅不等于 OpenAI API Key。GitHub Actions 自动调用大模型需要单独配置 API Key。
LLM_ENABLED=false
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=your_openai_model_here
LLM_MAX_ITEMS=10
LLM_STRICT_SOURCE=true
